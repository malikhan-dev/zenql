package collections

import (
	"Lingo/src/contracts"
	"fmt"
)

func CCollect[T any](query *Queryable[T]) ([]T, []contracts.OpError) {
	return query.Items, query.Err
}

func CCollectRange[T any](query *Queryable[T], cnt int) ([]T, []contracts.OpError) {

	if len(query.Items) >= cnt {
		return query.Items[0:cnt], query.Err
	} else {
		query.Err = append(query.Err, ErrFactory(5, fmt.Sprintf("CollectRange(%d)", cnt)))
	}
	return nil, query.Err

}

func PPipe[T any](query *Queryable[T], BufferSize int) <-chan contracts.CollectStream[T] {

	ch := make(chan contracts.CollectStream[T], BufferSize)

	go func() {

		defer close(ch)

		for _, v := range query.Items {
			ch <- contracts.CollectStream[T]{Value: v}
		}

	}()
	return ch
}

func CCollectGroup[K comparable, T any](query *GroupedQueryable[K, T]) (map[K][]T, []contracts.OpError) {
	return query.Items, query.Err
}
